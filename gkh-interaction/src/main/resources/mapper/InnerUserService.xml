<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.sxu.gkhinteraction.mapper.CommentMapper">

    <select id="selectCommentByDefault" resultType="cn.edu.sxu.gkhinteraction.domain.entity.Comment">
        SELECT *
        FROM tb_comment
        WHERE
            likes <![CDATA[ < ]]> (SELECT likes FROM tb_comment WHERE id = 1)
        AND
            id <![CDATA[ < ]]> 1
        ORDER BY likes DESC , id DESC;
    </select>
</mapper>
